# .env
# MongoDB Configuration
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password123
MONGODB_URL=mongodb://admin:password123@modern_tribes_mongodb:27017
MONGODB_DB_NAME=modern_tribes_mongodb

# Application Configuration
APP_NAME=Modern tribes application
APP_VERSION=1.0.0
DEBUG=True
HOST=localhost
PORT=8000

# File Upload Configuration
UPLOAD_DIR=/backend/uploads
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,webp
ALLOWED_FILE_EXTENSIONS=pdf,txt

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security Configuration
SECRET_KEY=1d8c9bc660bc50d75c57dffaee3a08230e3d3cb4449481bb44f19df50b284d6b
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=518400
MAGIC_LINK_EXPIRE_MINUTES=60

# Email Configuration (MailHog)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=no-reply@modern-tribes.com
EMAILS_FROM_NAME=no-reply-modern-tribes

# URLs
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Frontend Configuration (baked in at build time — set via CC_DOCKER_BUILD_ARGS on CleverCloud)
VITE_API_BASE_URL=http://localhost:8000/api

# Cellar S3-compatible object storage (CleverCloud — injected automatically when addon is linked)
CELLAR_ADDON_HOST=cellar-c2.services.clever-cloud.com
CELLAR_ADDON_KEY_ID=
CELLAR_ADDON_KEY_SECRET=
CELLAR_BUCKET_NAME=uploads

# Mongo Express Configuration
ME_CONFIG_MONGODB_SERVER=mongodb
ME_CONFIG_MONGODB_ENABLE_ADMIN=true
ME_CONFIG_MONGODB_ADMINUSERNAME=admin
ME_CONFIG_MONGODB_ADMINPASSWORD=password123
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin123